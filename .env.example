# ---- Data Configuration ----
DATA_DIR_PATH=your_data_directory_path
DATA_FILE_PATH=your_data_file_name.csv
DATA_FILE_TYPE=csv_or_parquet

# ---- MLflow Configuration ----
MLFLOW_TRACKING_URI=your_mlflow_tracking_uri
MLFLOW_EXPERIMENT_NAME=your_experiment_name

# ---- Model Configuration ----
MODEL_NAME=your_registered_model_name
MODEL_STAGE=Production_or_Staging
MODEL_SAVE_PATH=path/to/save/trained_model.pkl

# ---- UI Configuration ----
GRADIO_SERVER_NAME=localhost_or_0.0.0.0
GRADIO_PORT=your_port_number
GRADIO_SHARE=true_or_false

# ---- Categorical Columns ----
CATEGORICAL_COLUMNS=col1,col2,col3

# ---- Logging Configuration ----
LOG_LEVEL=DEBUG_or_INFO_or_WARNING

# ---- Feature Selection Configuration ----
DEFAULT_FEATURE_STRATEGY=all_or_kbest_f_or_kbest_mi
DEFAULT_FEATURE_PERCENTAGE=0.0_to_1.0

# ---- Reproducibility ----
RANDOM_STATE=your_integer_seed